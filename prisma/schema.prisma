generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL=postgres://neondb_owner:npg_tGLaeU2uWz4X@ep-white-grass-a1smnwlt-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require")
}

model account {
  id           Int       @id @default(autoincrement())
  name         String?   @db.VarChar(255)
  username     String?   @unique @db.VarChar(100)
  password     String?   @db.VarChar(255)
  phone        String?   @db.VarChar(20)
  role         String    @default("Khách hàng") @db.VarChar(50)
  active       String    @default("Hoạt động") @db.VarChar(50)
  created_at   DateTime? @default(now()) @db.Timestamptz(6)
  updated_at   DateTime? @default(now()) @db.Timestamptz(6)
  refreshtoken String?   @db.VarChar
  telegram     String?   @db.VarChar(20)
  amount       Int?      @default(0)
  team         String?
  position     String?

  @@index([username], map: "idx_account_username")
}

model attendance {
  id       Int      @id @default(autoincrement())
  username String   @db.VarChar(255)
  date     DateTime @db.Date
}

model customer_data {
  id         Int      @id @default(autoincrement())
  ma_moi     String?  @db.VarChar(100)
  phan_loai  String?  @db.VarChar(100)
  phien_ban  String?  @db.VarChar(100)
  ma_cu      String?
  cty        String?  @db.VarChar(50)
  ten        String[]
  telegram   String[]
  link_nhom  String?
  id_nhom    String?  @db.VarChar(100)
  nhom       String?  @db.VarChar(100)
  nguoi_cham String?  @db.VarChar(100)
  tab_don    String?
  cong_no    String?
  tin_dung   String?
  ngay_check String?
  tinh_trang String?  @db.VarChar(50)
  note_kt    String?
  note_khac  String?
}

model team {
  id          Int     @id @default(autoincrement())
  name        String?
  description String?
  active      String? @default("Hoạt động")
  created_at  String?
  updated_at  String?
}

model transactions {
  id           Int       @id @default(autoincrement())
  amount       String?
  deposit_date DateTime? @db.Date
  method       String?   @db.VarChar(50)
  description  String?   @db.VarChar(50)
  status       String?   @default("Đang chờ")
  customer_id  Int?
  name         String?
  type         String?   @default("recharge") @db.VarChar(30)
  wallet       String?
  address      String?   @default("TRC20")
}

model wheel {
  id       Int       @id @default(autoincrement())
  reward   String
  username String    @db.VarChar(255)
  date     DateTime? @default(now()) @db.Timestamp(6)
}
